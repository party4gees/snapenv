{
  "name": "snapenv",
  "version": "0.1.0",
  "description": "Snapshot and restore local environment variables across projects",
  "main": "src/index.js",
  "bin": {
    "snapenv": "./bin/snapenv.js"
  },
  "scripts": {
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "keywords": ["env", "dotenv", "snapshot", "cli", "environment"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "jest": "^29.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/*.test.js"],
    "collectCoverageFrom": ["src/**/*.js"]
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
